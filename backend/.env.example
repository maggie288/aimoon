# 复制为 .env 并填入真实值
# 获取方式：https://platform.minimaxi.com → 基础信息(GroupId) / 接口秘钥(API Key)
MINIMAX_API_KEY=your_api_key_here
MINIMAX_GROUP_ID=your_group_id_here
# 可选：TTS 接口 base URL，默认 https://api.minimaxi.com（国内）；国际可用 https://api.minimax.io
MINIMAX_IMAGE_BASE=https://api.minimaxi.com
# 可选：TTS 模型，如 speech-2.6-hd、speech-2.8-hd、speech-02-hd
# MINIMAX_TTS_MODEL=speech-2.6-hd
# 文生图接口 base URL，默认 https://api.minimax.io（国际）；国内可试 https://api.minimaxi.com
# MINIMAX_IMAGE_BASE=https://api.minimax.io
# 文生图调试时打开
# MINIMAX_IMAGE_DEBUG=1
