# ========== 生产部署（Vercel） ==========
# 后端 API 地址。不设则开发时请求 http://localhost:8000
# NEXT_PUBLIC_API_ORIGIN=https://your-api.railway.app

# 收款地址（可只设一种或两种都设）
# 比特币 (BTC)
# NEXT_PUBLIC_BTC_ADDRESS=bc1q...
# TRON 钱包地址（TRX / USDT-TRC20），以 T 开头的那串
# NEXT_PUBLIC_TRON_ADDRESS=T...

# 广告 - 可只配一种或多种（不同广告位用不同 provider）
# Google AdSense（AdSlot 默认 provider="google"）
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT=1234567890

# Carbon Ads（开发者向、隐私友好）。申请：carbonads.net，在页面用 provider="carbon"
# NEXT_PUBLIC_CARBON_SERVE=你的 serve code
# NEXT_PUBLIC_CARBON_PLACEMENT=你的 placement（如站点名）

# 自定义广告脚本（如 Ethical Ads、Media.net）。用 provider="custom" 的 AdSlot 会加载此脚本
# NEXT_PUBLIC_ALT_AD_SCRIPT_URL=https://...
